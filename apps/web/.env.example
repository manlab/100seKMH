# 백세한방병원 — 환경변수 예제
# 실 운영 전 .env.local 또는 배포 플랫폼(Vercel 등)에 동일 키로 설정.

# === Resend (온라인 상담 이메일 전송) ===
# https://resend.com 가입 → API Keys에서 발급
# 미설정 시: 개발 모드는 콘솔 로그로 대체, 운영 모드는 502 에러 응답
RESEND_API_KEY=

# 상담 글이 도착할 병원 운영팀 이메일 (수신자)
COUNSEL_TO_EMAIL=ops@baeksehospital.kr

# 발신자 이메일 (Resend에서 verified domain 필요)
# 개발용: "백세한방병원 <onboarding@resend.dev>" (Resend 기본 발신 도메인)
# 운영용: "백세한방병원 <noreply@baeksehospital.kr>" (DNS 인증 후)
RESEND_FROM_EMAIL=백세한방병원 <onboarding@resend.dev>

# === 사이트 ===
# 이메일 본문·canonical·sitemap 링크에 사용
NEXT_PUBLIC_SITE_URL=https://baeksehospital.kr

# === 선택 (개원 후 발급 시 추가) ===
# NEXT_PUBLIC_KAKAO_MAP_KEY=
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_NAVER_WCS_ID=
