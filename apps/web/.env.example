# 백세한방병원 — 환경변수 예제
# 실 운영 전 .env.local 또는 배포 플랫폼(Vercel 등)에 동일 키로 설정.

# === Postgres (Vercel Storage → Postgres 연결 시 자동 주입) ===
# 로컬 개발: 다음 둘 중 하나
#   1) `vercel env pull .env.local` → 운영 DB 와 동일한 자격증명을 로컬에 동기화
#   2) Docker 등으로 로컬 PG 띄우고 직접 입력
POSTGRES_URL=postgres://user:pass@host:5432/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:pass@host:5432/dbname?sslmode=require

# === 암호화 / 인증 비밀 ===
# 휴대전화번호 AES-256-GCM 키. 절대 git 에 커밋하지 말 것.
# 생성: `openssl rand -hex 32`
PHONE_ENC_KEY=

# 어드민 세션 토큰 서명 비밀 (≥32자).
# 생성: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=

# 첫 어드민 생성용 1회성 토큰 (≥32자).
# /api/admin/seed 엔드포인트 보호용. admin_users 비어있을 때만 동작.
# 생성: `openssl rand -hex 32`
ADMIN_SEED_TOKEN=

# === Resend (온라인 상담 이메일 전송) ===
# https://resend.com 가입 → API Keys에서 발급
# 미설정 시: 개발 모드는 콘솔 로그로 대체, 운영 모드는 502 에러 응답
RESEND_API_KEY=

# 상담 글이 도착할 병원 운영팀 이메일 (수신자)
COUNSEL_TO_EMAIL=6334shin@naver.com

# 발신자 이메일 (Resend에서 verified domain 필요)
# 개발용: "백세한방병원 <onboarding@resend.dev>" (Resend 기본 발신 도메인)
# 운영용: "백세한방병원 <noreply@baeksehospital.kr>" (DNS 인증 후)
RESEND_FROM_EMAIL=백세한방병원 <onboarding@resend.dev>

# === 사이트 ===
# 이메일 본문·canonical·sitemap 링크에 사용
NEXT_PUBLIC_SITE_URL=https://baeksehospital.kr

# === 선택 (개원 후 발급 시 추가) ===
# NEXT_PUBLIC_KAKAO_MAP_KEY=
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_NAVER_WCS_ID=
